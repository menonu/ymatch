# New Relic secrets — supplied to Terraform as TF_VAR_* env vars.
#
# Copy to terraform/newrelic/.env and fill in real values. .env is
# gitignored (**/.env in .gitignore) — never commit it.
#
# The task targets (tf:newrelic:plan / tf:newrelic:apply) source this file
# automatically (`set -a; . ./.env; set +a`) before running terraform, so
# you do not export anything by hand. See docs/how_to/terraform_apply.md.
#
# Precedence note: terraform.tfvars OVERRIDES TF_VAR_ env vars, so each
# secret must appear ONLY here (not in terraform.tfvars).

TF_VAR_api_key="NRAK-YOUR_NEW_RELIC_USER_API_KEY"
TF_VAR_nr_license_key="YOUR_NEW_RELIC_INGEST_LICENSE_KEY"
TF_VAR_discord_webhook_url="https://discord.com/api/webhooks/YOUR/DISCORD_WEBHOOK"