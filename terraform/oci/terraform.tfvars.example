# OCI Terraform variables template (non-secret config).
# Copy to terraform/oci/terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit it.
#
# SECRETS do NOT go here. They are supplied via TF_VAR_* env vars from a
# gitignored .env — see terraform/oci/.env.example and
# docs/how_to/terraform_apply.md. (Terraform precedence: terraform.tfvars
# overrides TF_VAR_ env, so a given variable must live in only one place.)
# Secrets / sensitive in .env: db_password, nr_license_key, nr_account_id,
# alert_email, db_backup_user_email.

# OCI authentication
tenancy_ocid     = "ocid1.tenancy.oc1..YOUR_TENANCY_OCID"
user_ocid        = "ocid1.user.oc1..YOUR_USER_OCID"
fingerprint      = "XX:XX:XX:XX:XX:XX:XX:XX:XX:XX:XX:XX:XX:XX:XX:XX"
private_key_path = "/path/to/your/oci_api_key.pem"
region           = "ap-osaka-1"
compartment_ocid = "ocid1.tenancy.oc1..YOUR_TENANCY_OCID"

# SSH public keys (for VM access)
# Generate with: ssh-keygen -t ed25519 -C "ymatch-oci" -f ~/.ssh/oci_ymatch
ssh_public_key_v2       = "ssh-ed25519 AAAA... ymatch-oci-v2"
ssh_public_key_staging  = "ssh-ed25519 AAAA... ymatch-oci-staging"

# Instance sizing.
# OCI Always Free A1 quota is 4 OCPUs / 24 GB total across all A1 instances.
# With prod (2 OCPU / 12 GB) + staging (1 OCPU / 4 GB) = 3 OCPU / 16 GB, leaving
# headroom. The retired v1 instance must be destroyed before apply (issue #209).
instance_ocpus             = 2
instance_memory_gb         = 12
staging_instance_ocpus     = 1
staging_instance_memory_gb = 4
boot_volume_size_gb        = 50

# NR display names (unique per instance, set here so each instance is
# distinguishable in the New Relic Infrastructure dashboard).
nr_display_name         = "ymatch-oci-arm-v2"
nr_display_name_staging = "ymatch-oci-arm-staging"
