# OCI + New Relic secrets — supplied to Terraform as TF_VAR_* env vars.
#
# Copy to terraform/oci/.env and fill in real values. .env is gitignored
# (**/.env in .gitignore) — never commit it.
#
# The task targets (tf:oci:plan / tf:oci:apply) source this file
# automatically (`set -a; . ./.env; set +a`) before running terraform, so
# you do not export anything by hand. See docs/how_to/terraform_apply.md.
#
# Precedence note: terraform.tfvars OVERRIDES TF_VAR_ env vars, so each
# secret must appear ONLY here (not in terraform.tfvars). The non-secret
# config (OCIDs, region, sizing, SSH public keys, nr_display_name) stays
# in terraform/oci/terraform.tfvars.

TF_VAR_db_password="your_secure_db_password"
TF_VAR_nr_license_key="YOUR_NEW_RELIC_INGEST_LICENSE_KEY"
TF_VAR_nr_account_id="YOUR_NEW_RELIC_ACCOUNT_ID"
TF_VAR_alert_email="you@example.com"