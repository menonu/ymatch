# Backend local environment template
# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored.

# Local development
DATABASE_URL=postgres://ymatch_user:secure_dev_password@localhost:5432/ymatch_db
RUST_LOG=debug

# ============================================
# Terraform / OCI Deployment Secrets
# ============================================
# Source this file before running terraform:
#   set -a && source backend/.env && set +a && terraform apply

# New Relic Infrastructure agent license key
TF_VAR_nr_license_key=replace_with_real_value

# New Relic Account ID (for Flex integration)
TF_VAR_nr_account_id=replace_with_real_value

# Email for OCI budget alerts
TF_VAR_alert_email=replace_with_real_value
