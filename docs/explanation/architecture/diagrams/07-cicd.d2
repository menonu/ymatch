direction: right
title: |md
  # CI/CD sketch
| {near: top-center}

pr: "Pull request" { style.fill: "#BBDEFB" }
ci: "ci.yml / coverage / e2e" { style.fill: "#90CAF9" }
main: "merge to main" { style.fill: "#A5D6A7" }
dep_p: "deploy-oci.yml" { style.fill: "#FFE082" }
dep_s: "deploy-oci-staging.yml" { style.fill: "#FFE082" }
prod: "Prod VM compose" { style.fill: "#81C784" }
stg: "Staging VM compose" { style.fill: "#81C784" }

pr -> ci -> main
main -> dep_p -> prod
main -> dep_s -> stg
