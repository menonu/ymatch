# Caddy reverse proxy for OCI STAGING deployment
# Uses nip.io for wildcard DNS → auto-SSL via Let's Encrypt
# Staging runs on ports 8080/8443
#
# {$PUBLIC_IP} is injected from docker-compose.oci.yml environment

:80 {
    handle /api/* {
        reverse_proxy staging_backend:3000
    }

    handle /uploads/* {
        reverse_proxy staging_backend:3000
    }

    handle {
        reverse_proxy staging_frontend:80
    }
}
